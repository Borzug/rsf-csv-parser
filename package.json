{
    "name": "rsf-rally-csv",
    "version": "1.0.0",
    "description": "Rally progress chart from CSV results",
    "author": "Claude/Borzug",
    "scripts": {
        "build":     "esbuild src/renderer/index.ts --bundle --outfile=dist/renderer/index.js --platform=browser --target=es2020",
        "dev":       "esbuild src/renderer/index.ts --bundle --outfile=dist/renderer/index.js --platform=browser --target=es2020 --watch",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "esbuild":    "^0.25.0",
        "typescript": "^5.5.0"
    }
}
